# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# OS / editor cruft
.DS_Store
Thumbs.db

# Claude Code / OMC session state (not part of kniox)
.omc/

# Secrets
.env
*.env

# Shadow-Git gate worktrees (ephemeral; created/removed by daemon/shadow.py)
.kniox/

# Generated, machine-specific state (regenerated by `kx setup`)
daemon/state/*
!daemon/state/.gitkeep
*.db
*.log

# User projects — keep the folder, not its contents. Personal projects are PRIVATE:
# their names/ideas must never enter this PUBLIC repo (enforced by guard-privacy.py).
projects/*
!projects/.gitkeep

# Per-project dashboard slots are named after personal projects → never tracked.
# The dashboard renders projects dynamically from the local daemon registry instead.
dashboard/*/

# Conversation corpus (ROADMAP item 1) — private, large, per-machine; never committed
corpus/

# custodian generated reports + state (artifacts, like daemon/state)
custodian/

# corn scout runtime lock (logs already covered by *.log)
corn/.scout.lock
